{
  "functions": {
    "src/app/api/chat/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/sessions/*/evaluate/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/cron/research/poll/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/admin/research/scan/poll/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/research",
      "schedule": "0 11 * * 1"
    },
    {
      "path": "/api/cron/research/poll",
      "schedule": "*/15 11-14 * * 1"
    },
    {
      "path": "/api/cron/cleanup-sessions",
      "schedule": "0 6 * * *"
    }
  ]
}
