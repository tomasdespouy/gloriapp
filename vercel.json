{
  "functions": {
    "src/app/api/chat/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/sessions/*/evaluate/route.ts": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/cron/research",
      "schedule": "0 11 * * 1"
    },
    {
      "path": "/api/cron/cleanup-sessions",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/pilots-autostatus",
      "schedule": "0 * * * *"
    }
  ]
}
