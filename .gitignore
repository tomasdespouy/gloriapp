# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# documents & reports (not source code)
*.pdf
*.docx
*.doc
*.xlsx
*.jpg
*.jpeg
!public/branding/*.jpg
avatares.*
imagenes/

# patient videos (stored in Supabase Storage)
public/patients/*.mp4

# temp/test images and videos
_test_*
_v4_*
_check_*
_videos_v3/
.luma-gen-ids.json
.tmp_*
*.csv
scripts/__pycache__/
public/learning/originals/

# simulation data (not needed in prod)
public/*.json
public/*.txt
.env*.local

# pilot report data — contiene PII (nombres, emails, transcripts de chat).
# Los scripts extractores generan archivos informes/*-pilot-data.json que
# NO se commitean. El .docx generado tampoco porque tambien tiene nombres
# y citas textuales. Si se quiere archivar un informe por razones de
# traceability, subir a Drive/supradmin separado, no al repo.
informes/*-pilot-data.json
informes/pilotos/*.docx
informes/pilotos/*.pdf

# spike experimental: modelo de Picovoice Eagle (4.6 MB). No se commitea
# para no engordar el repo. Re-bajarlo con el README del spike.
public/eagle_params.pv
